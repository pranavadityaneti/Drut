# Copy this file to .env.local (NOT committed) and fill in the real values.

# ---------- Gemini ----------
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ---------- Supabase (public) ----------
# These ship to the browser bundle — safe to commit, kept here for clarity.
# In WaitlistClassic / WaitlistModern these are hardcoded fallbacks already.
# VITE_SUPABASE_URL=https://ukrtaerwaxekonislnpw.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ---------- Razorpay (PUBLIC key only — secret stays server-side) ----------
# Get from https://dashboard.razorpay.com → Settings → API Keys
# Test mode keys start with `rzp_test_`, live with `rzp_live_`.
# The SECRET key MUST NOT be set here — it lives only in Supabase Edge
# Function env (Settings → Edge Functions → Add Secret) where the
# create-razorpay-order / verify-razorpay-payment functions can read it.
VITE_RAZORPAY_KEY_ID=rzp_test_T2jRuzUXRkbRVx
