{
  "expo": {
    "name": "Drut",
    "slug": "drut",
    "owner": "pranavadityaneti",
    "scheme": "drut-mobile",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/c78d8372-341b-46df-88c0-9bb2180e1ff0"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#b4fa8d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "club.drut.app",
      "associatedDomains": [
        "applinks:drut.club"
      ],
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Drut needs access to your photos so you can set a profile picture.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "2"
    },
    "android": {
      "package": "club.drut.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#b4fa8d"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "drut.club"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-notifications",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.355443227173-j573baeitjqh23eslo6el1fn0u31224d"
        }
      ],
      "./plugins/withModularHeaders"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c78d8372-341b-46df-88c0-9bb2180e1ff0"
      }
    }
  }
}
