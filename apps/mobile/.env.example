# Copy this file to apps/mobile/.env (NOT committed) and fill in real values.
# EXPO_PUBLIC_* vars are inlined into the JS bundle, so they can be set here.
# Secrets MUST NOT live in EXPO_PUBLIC_ — use EAS secrets for those instead.

# ---------- Google Sign-In ----------
# Set up steps:
#   1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
#   2. Make one WEB client (used by Supabase + by the mobile lib to verify the idToken)
#   3. Make one iOS client (bundle: club.drut.mobile)
#   4. Make one Android client (package: club.drut.mobile, SHA-1 from your keystore)
#   5. Paste the WEB client id below
#   6. Paste the iOS client id below
#   7. In Supabase Auth → Providers → Google: paste the WEB client id + WEB client secret
#   8. In app.json plugin block: replace REPLACE_WITH_IOS_OAUTH_CLIENT_REVERSED with the
#      reversed iOS client (e.g. 1234-abcdef → com.googleusercontent.apps.1234-abcdef)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
