{
    "buildCommand": "cd apps/web && npm run build",
    "outputDirectory": "apps/web/dist",
    "installCommand": "npm install --legacy-peer-deps && cd apps/web && npm install --legacy-peer-deps",
    "framework": "vite",
    "redirects": [
        {
            "source": "/",
            "has": [{ "type": "host", "value": "admin.drut.club" }],
            "destination": "/admin",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/landing/(.*)",
            "destination": "/landing/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}